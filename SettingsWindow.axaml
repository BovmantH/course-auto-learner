<Window x:Class="CourseAutoLearner.SettingsWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="520" Height="360"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="快速选择" VerticalAlignment="Center"
                   FontSize="13" Foreground="#1E293B" Margin="0,0,0,12" />
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CmbPreset"
                  FontSize="13" Margin="0,0,0,12"
                  SelectionChanged="Preset_SelectionChanged">
            <ComboBoxItem Content="自定义" />
            <ComboBoxItem Content="DeepSeek" />
            <ComboBoxItem Content="Kimi (月之暗面)" />
            <ComboBoxItem Content="通义千问 (阿里)" />
            <ComboBoxItem Content="智谱 GLM" />
            <ComboBoxItem Content="豆包 (字节)" />
            <ComboBoxItem Content="小米 MiMo" />
            <ComboBoxItem Content="OpenAI" />
        </ComboBox>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="接口地址" VerticalAlignment="Center"
                   FontSize="13" Foreground="#1E293B" Margin="0,0,0,12" />
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtBaseUrl"
                 FontSize="13" Padding="6,4" Margin="0,0,0,12" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key" VerticalAlignment="Center"
                   FontSize="13" Foreground="#1E293B" Margin="0,0,0,12" />
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtApiKey"
                 PasswordChar="•" FontSize="13" Padding="6,4" Margin="0,0,0,12" />

        <TextBlock Grid.Row="3" Grid.Column="0" Text="模型名称" VerticalAlignment="Center"
                   FontSize="13" Foreground="#1E293B" Margin="0,0,0,12" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtModel"
                 FontSize="13" Padding="6,4" Margin="0,0,0,12" />

        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                   Text="支持所有 OpenAI 兼容接口。未配置接口时，自测题目将跳过不作答。" Margin="0,0,0,8" />

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消"
                    Classes="action-btn"
                    Background="#E2E8F0" Foreground="#1E293B"
                    Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="保存"
                    Classes="action-btn"
                    Background="#2563EB" Foreground="White"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
